# Copy to .env and fill in real values. .env is gitignored.
# The framework reads only the env var NAMES referenced in provider config,
# never the values directly.

# --- Zero-cost LLM providers (free tiers) ---
# Groq (fast, OpenAI-compatible). Multiple keys enable pool rotation on 429.
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

# OpenRouter (aggregator, has :free models)
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=

# Google Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY_1=

# --- Paid (added later) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Zetryn models (subscription) ---
# Generate at zetryn.com. Used by ZetrynClient.from_env() as the bearer token.
# ZETRYN_API_KEY=zk_live_...
